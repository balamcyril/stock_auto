###> symfony/framework-bundle ###
# Change this to a unique secret for your production environment
# Generate with: php -r 'echo bin2hex(random_bytes(16));'
APP_SECRET=change_this_to_a_unique_secret_for_production
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Configure with your actual production database credentials
# Format: mysql://username:password@hostname:port/database_name?serverVersion=version&charset=utf8mb4
DATABASE_URL="mysql://prod_user:prod_password@localhost:3306/stock_auto_prod?serverVersion=8.2&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
# Set to your actual production domain
CORS_ALLOW_ORIGIN='^https?://(yourdomain\.com|www\.yourdomain\.com)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
# If you need to regenerate JWT keys, run:
# php bin/console lexik:jwt:generate-keypair
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your_jwt_passphrase_here
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
# Configure your email service for production
# Example for Gmail: MAILER_DSN=gmail+smtp://your_email@gmail.com:your_app_password@default
# Example for SendGrid: MAILER_DSN=sendgrid+api://SG.xxxxxxxxxxxxx@default
# MAILER_DSN=smtp://username:password@smtp.example.com:587?encryption=tls
###< symfony/mailer ###
