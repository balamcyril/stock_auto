{% extends '@EasyAdmin/layout.html.twig' %}

{% macro stat_card(title, value, controller, details) %}
    <div class="col-md-3 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">{{ title }}</h5>
                <p class="card-text mb-1">Nombre total: {{ value }}</p>
                {% if details %}
                    <p class="text-muted small mb-2">{{ details }}</p>
                {% endif %}
                {% if controller %}
                    <a href="{{ ea_url().setController(controller).setAction('index') }}">Voir les details</a>
                {% endif %}
            </div>
        </div>
    </div>
{% endmacro %}

{% import _self as dashboard %}

{% block content %}
    <div class="container-fluid">
        <h2 class="mb-4">Stock Auto</h2>

        <h4 class="mb-3">Indicateurs stock et ventes</h4>
        <div class="row">
            {{ dashboard.stat_card('Pièces actives', activeProductCount, 'App\\Controller\\Admin\\ProductCrudController', productCount ~ ' pièces au total') }}
            {{ dashboard.stat_card('Stock bas', lowStockProductCount, 'App\\Controller\\Admin\\ProductCrudController', outOfStockProductCount ~ ' pièces en rupture') }}
            {{ dashboard.stat_card('Valeur du stock', stockValue|number_format(2, ',', ' ') ~ ' EUR', 'App\\Controller\\Admin\\ProductCrudController', 'Prix x quantité disponible') }}
            {{ dashboard.stat_card('Commandes à traiter', pendingOrderCount, 'App\\Controller\\Admin\\OrderCrudController', orderCount ~ ' commandes au total') }}
            {{ dashboard.stat_card('CA payé', paidRevenue|number_format(2, ',', ' ') ~ ' EUR', 'App\\Controller\\Admin\\OrderCrudController', 'Commandes marquées payées') }}
            {{ dashboard.stat_card('Paiements en attente', pendingPaymentCount, 'App\\Controller\\Admin\\PaymentCrudController', paymentCount ~ ' paiements au total') }}
            {{ dashboard.stat_card('Mouvements de stock', stockMovementCount, 'App\\Controller\\Admin\\StockMovementCrudController', 'Historique entrées / sorties') }}
            {{ dashboard.stat_card('Utilisateurs', userCount, 'App\\Controller\\Admin\\UserCrudController', cartCount ~ ' paniers créés') }}
        </div>

        <h4 class="mb-3 mt-4">Catalogue</h4>
        <div class="row">
            {{ dashboard.stat_card('Pièces', productCount, 'App\\Controller\\Admin\\ProductCrudController', '5 emplacements photo par pièce') }}
            {{ dashboard.stat_card('Marques', brandCount, 'App\\Controller\\Admin\\BrandCrudController', null) }}
            {{ dashboard.stat_card('Catégories', categoryCount, 'App\\Controller\\Admin\\CategoryCrudController', subCategoryCount ~ ' sous-catégories') }}
            {{ dashboard.stat_card('Sous-catégories', subCategoryCount, 'App\\Controller\\Admin\\SubCategoryCrudController', null) }}
        </div>

        <h4 class="mb-3 mt-4">Logistique</h4>
        <div class="row">
            {{ dashboard.stat_card('Entrepôts', warehouseCount, 'App\\Controller\\Admin\\WarehouseCrudController', productLocationCount ~ ' emplacements') }}
            {{ dashboard.stat_card('Emplacements produits', productLocationCount, 'App\\Controller\\Admin\\ProductLocationCrudController', null) }}
            {{ dashboard.stat_card('Points de retrait', pickupLocationCount, 'App\\Controller\\Admin\\PickupLocationCrudController', null) }}
        </div>

        <h4 class="mb-3 mt-4">Ventes</h4>
        <div class="row">
            {{ dashboard.stat_card('Paniers', cartCount, 'App\\Controller\\Admin\\CartCrudController', cartItemCount ~ ' articles panier') }}
            {{ dashboard.stat_card('Articles panier', cartItemCount, 'App\\Controller\\Admin\\CartItemCrudController', null) }}
            {{ dashboard.stat_card('Commandes', orderCount, 'App\\Controller\\Admin\\OrderCrudController', orderItemCount ~ ' articles commande') }}
            {{ dashboard.stat_card('Articles commande', orderItemCount, 'App\\Controller\\Admin\\OrderItemCrudController', null) }}
            {{ dashboard.stat_card('Paiements', paymentCount, 'App\\Controller\\Admin\\PaymentCrudController', null) }}
        </div>
    </div>
{% endblock %}
